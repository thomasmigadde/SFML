{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Active File",
            "type": "shell",
            "command": "g++",
            "args": [
                "-g",
              //  "${file}\\${relativeFile}",
              // "${workplaceFolder}",
               // "GAME/*.cpp",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}.exe",
                "-I",
                "D:/SCHOOL/SFML-3.0.2/include",
                "-I", "C:/Users/User/Desktop/SFML/GAME",
                "-L",
                "D:/SCHOOL/SFML-3.0.2/lib",
                "-lsfml-graphics",
                "-lsfml-window",
                "-lsfml-system",
                "-std=c++17"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "Build current C++ SFML file"
        },
        {
            "label": "Build Game",
            "type": "shell",
            "command": "g++",
            "args": [
                "-g",
                "game.cpp",
                "-o",
                "game.exe",
                "-ISFML/include",
                "-LSFML/lib",
                "-lsfml-graphics",
                "-lsfml-window",
                "-lsfml-system",
                "-std=c++17"
            ],
            "group": "build",
            "problemMatcher": ["$gcc"]
        }
    ]
}

